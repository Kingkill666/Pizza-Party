{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "build": {
    "env": {
      "NEXT_PUBLIC_DEPLOYMENT_VERSION": "997ff9e",
      "NEXT_PUBLIC_FORCE_DEPLOYMENT": "true"
    }
  },
  "functions": {
    "app/**/*.tsx": {
      "maxDuration": 30
    }
  },
  "regions": ["iad1"]
} 